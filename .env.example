VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# Structure A(서버 콜러블 submitProtectedSurveyResponse) 전환 플래그.
# "true"가 아니면(미설정 포함) 항상 false로 취급되어 기존 클라이언트 트랜잭션 경로를 쓴다.
# 배포 순서는 docs/pii-encryption-architecture.md §11.8 참조 — 서버 함수 배포·smoke test 이후에만 켤 것.
VITE_USE_SERVER_RESPONSE_SUBMISSION=false

# ⚠️ 임시 조치 플래그(2026-07-14) — Cloud Functions(encryptRespondentPii/encryptAnswerFields,
# Cloud KMS) 호출 여부. 이 값이 "true"가 아닌 동안(기본값, 현재 운영 상태) 이름/전화/생년월일/
# 자유서술형 개인정보 문항은 Firestore에 **암호화되지 않은 평문으로 저장된다** — 개인정보
# 보호가 해결된 상태가 아니라, 배포되지 않은 Cloud Functions를 호출해 브라우저 콘솔에 CORS
# 오류만 남기던 것을 막은 임시 조치일 뿐이다(원본 유실은 없다 — 참고:
# docs/admin-original-pii-export-fix.md — 하지만 "유실 없음"이 "보호됨"을 뜻하지 않는다).
# 이 값을 true로 바꾸기 전에 반드시: (1) Cloud Functions가 실제로 배포되어 있는지
# `firebase functions:list`로 확인, (2) Blaze 요금제 전환 여부 확인. 배포 안 된 채로 켜면
# 이 절이 막았던 CORS 콘솔 오류가 그대로 재발한다(자동 검증 장치 없음).
# 최종 구조(서버 측 암호화 + 별도 저장소 + 관리자 다운로드 시에만 복호화)는
# docs/pii-encryption-architecture.md §11.14 참고.
VITE_ENABLE_PII_ENCRYPTION=false
