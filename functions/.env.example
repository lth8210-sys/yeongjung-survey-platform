# functions/.env.example
# 실제 값은 여기 채우지 않는다 — 이 파일은 예시일 뿐이다.
#
# 배포 시 설정 방법(공식 2nd-gen 파라미터, functions.config() 아님):
#   firebase functions:config는 더 이상 사용하지 않는다. 대신 다음 중 하나로 설정한다.
#   1) firebase apphosting/functions 배포 시 --set-params, 또는
#   2) functions/.env.<project-id> 파일 (배포 대상 프로젝트별, git에 커밋하지 않는다)
#   공식 문서: https://firebase.google.com/docs/functions/config-env?gen=2nd
#
# PII_KMS_KEY_NAME 값 자체는 "비밀"이 아니다(키 리소스 이름일 뿐 키 자료가 아니다) —
# 그러나 이 값이 가리키는 Cloud KMS 키에 대한 IAM 권한(cloudkms.cryptoKeyEncrypterDecrypter)은
# 이 Cloud Functions 서비스 계정에만 부여해야 한다.
PII_KMS_KEY_NAME=projects/YOUR_PROJECT_ID/locations/asia-northeast3/keyRings/survey-pii/cryptoKeys/respondent-pii
