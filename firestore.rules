rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userEmail() {
      return isSignedIn() ? request.auth.token.email : '';
    }

    function isInternalEmailValue(email) {
      return email is string &&
        email.matches('.*@[Yy][Ee][Oo][Nn][Gg][Jj][Uu][Nn][Gg]\\.[Oo][Rr]\\.[Kk][Rr]$');
    }

    function isInternalUser() {
      return isSignedIn() && (
        hasUserDoc() ||
        isInternalEmailValue(userEmail())
      );
    }

    // SYNC REQUIRED: 이 목록을 변경하면 아래 protectedSuperAdminEmail()과
    // src/firebase/users.js의 SUPER_ADMIN_EMAILS도 함께 변경해야 합니다.
    function isProtectedSuperAdminEmailValue(email) {
      return email in [
        "lth8210@yeongjung.or.kr",
        "yj100@yeongjung.or.kr"
      ];
    }

    function isSuperAdminEmail() {
      return isProtectedSuperAdminEmailValue(userEmail());
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function hasUserDoc() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function resolvedRole(hasDoc, data, email) {
      return isProtectedSuperAdminEmailValue(email) ||
        (
          hasDoc &&
          (
            normalizeStoredRole(data.role) == 'super_admin' ||
            isProtectedSuperAdminEmailValue(data.email)
          )
        )
        ? 'super_admin'
        : hasDoc
          ? normalizeStoredRole(data.role)
          : isInternalEmailValue(email)
            ? 'creator'
            : '';
    }

    function resolvedStatus(hasDoc, data, email, role) {
      return role == 'super_admin'
        ? 'active'
        : hasDoc
          ? normalizeStoredUserStatus(data)
          : isInternalEmailValue(email)
            ? 'active'
            : '';
    }

    function currentRole() {
      let email = userEmail();
      let hasDoc = isSignedIn() && hasUserDoc();
      let data = hasDoc ? userDoc().data : {};

      return resolvedRole(hasDoc, data, email);
    }

    function currentStatus() {
      let email = userEmail();
      let hasDoc = isSignedIn() && hasUserDoc();
      let data = hasDoc ? userDoc().data : {};
      let role = resolvedRole(hasDoc, data, email);

      return resolvedStatus(hasDoc, data, email, role);
    }

    function normalizeStoredRole(role) {
      return role == '슈퍼관리자'
        ? 'super_admin'
        : role == '관리자'
          ? 'admin'
          : role == '제작자'
            ? 'creator'
        : role == '조회자'
          ? 'viewer'
          : role == '직원'
            ? 'viewer'
            : role == 'staff'
              ? 'viewer'
              : role == 'superAdmin'
                ? 'super_admin'
                : role == 'super_admin'
                  ? 'super_admin'
                  : role == 'superadmin'
                    ? 'super_admin'
              : role;
    }

    function normalizeStoredStatus(status) {
      return status == '활성'
        ? 'active'
        : status == '승인 대기'
          ? 'pending'
          : status == '비활성'
            ? 'inactive'
            : status == '차단'
              ? 'blocked'
              : status == null
                ? 'active'
                : status;
    }

    function hasActiveStatusFlag(data) {
      return (
        data.keys().hasAny(['status']) &&
        normalizeStoredStatus(data.status) == 'active'
      ) || (
        data.keys().hasAny(['isActive']) &&
        data.isActive == true
      ) || (
        data.keys().hasAny(['active']) &&
        data.active == true
      ) || (
        data.keys().hasAny(['is_active']) &&
        data.is_active == true
      );
    }

    function normalizeStoredUserStatus(data) {
      return hasActiveStatusFlag(data)
        ? 'active'
        : data.keys().hasAny(['status'])
          ? normalizeStoredStatus(data.status)
          : data.keys().hasAny(['isActive']) && data.isActive is bool
            ? (data.isActive ? 'active' : 'inactive')
            : data.keys().hasAny(['active']) && data.active is bool
              ? (data.active ? 'active' : 'inactive')
              : data.keys().hasAny(['is_active']) && data.is_active is bool
                ? (data.is_active ? 'active' : 'inactive')
                : 'active';
    }

    function isAtLeastAdmin() {
      return currentStatus() == 'active' && currentRole() in ['super_admin', 'admin'];
    }

    function isCreator() {
      return currentStatus() == 'active' &&
        currentRole() == 'creator';
    }

    function normalizedSurveyVisibility(data) {
      return data.visibility == "organization" ? "organization" : "private";
    }

    function isOrganizationVisibleSurvey(data) {
      return normalizedSurveyVisibility(data) == "organization";
    }

    function requestRole() {
      return normalizeStoredRole(request.resource.data.role);
    }

    function membershipDoc(email) {
      return get(/databases/$(database)/documents/memberships/$(email));
    }

    function membershipById(membershipId) {
      return get(/databases/$(database)/documents/memberships/$(membershipId));
    }

    function hasMembership(email) {
      return exists(/databases/$(database)/documents/memberships/$(email));
    }

    function hasMembershipById(membershipId) {
      return membershipId is string &&
        exists(/databases/$(database)/documents/memberships/$(membershipId));
    }

    function normalizedMembershipRole(email) {
      return hasMembership(email)
        ? normalizeStoredRole(membershipDoc(email).data.role)
        : '';
    }

    function normalizedMembershipRoleById(membershipId) {
      return hasMembershipById(membershipId)
        ? normalizeStoredRole(membershipById(membershipId).data.role)
        : '';
    }

    function membershipEmailById(membershipId) {
      return hasMembershipById(membershipId)
        ? membershipById(membershipId).data.email
        : '';
    }

    // SYNC REQUIRED: 위 isSuperAdminEmail() 및 src/firebase/users.js SUPER_ADMIN_EMAILS와 동일하게 유지.
    function protectedSuperAdminEmail(email) {
      return isProtectedSuperAdminEmailValue(email);
    }

    function protectedSuperAdminData(data) {
      return data.role == 'super_admin' || protectedSuperAdminEmail(data.email);
    }

    function isLegacyPublishedStatus(data) {
      return data.status == "active";
    }

    function surveyStatusForRead(data) {
      return data.status in ["published", "closed"] || isLegacyPublishedStatus(data);
    }

    function surveyStatusForResponse(data) {
      return data.status == "published" || isLegacyPublishedStatus(data);
    }

    function isSurveyOwner(data) {
      return isSignedIn() && (
        data.ownerUid == request.auth.uid ||
        data.createdByUid == request.auth.uid ||
        data.ownerId == request.auth.uid ||
        data.userId == request.auth.uid ||
        data.ownerEmail == userEmail() ||
        data.createdByEmail == userEmail() ||
        (data.createdBy is map && (
          data.createdBy.uid == request.auth.uid ||
          data.createdBy.email == userEmail()
        ))
      );
    }

    function isResponseOwner(data) {
      return isSignedIn() && (
        data.surveyOwnerUid == request.auth.uid ||
        data.surveyCreatedByUid == request.auth.uid ||
        data.surveyOwnerEmail == userEmail() ||
        data.surveyCreatedByEmail == userEmail()
      );
    }

    function canReadManagedSurveyWithAccess(data, role, status) {
      return status == 'active' && (
        role in ['super_admin', 'admin'] ||
        (role == 'creator' && isSurveyOwner(data)) ||
        isOrganizationVisibleSurvey(data)
      );
    }

    function canEditManagedSurveyWithAccess(data, role, status) {
      return status == 'active' && (
        role in ['super_admin', 'admin'] ||
        (role == 'creator' && isSurveyOwner(data))
      );
    }

    function canReadManagedSurvey(data) {
      let email = userEmail();
      let hasDoc = isSignedIn() && hasUserDoc();
      let userData = hasDoc ? userDoc().data : {};
      let role = resolvedRole(hasDoc, userData, email);
      let status = resolvedStatus(hasDoc, userData, email, role);

      return canReadManagedSurveyWithAccess(data, role, status);
    }

    function canListManagedSurveys(data) {
      let email = userEmail();
      let hasDoc = isSignedIn() && hasUserDoc();
      let userData = hasDoc ? userDoc().data : {};
      let role = resolvedRole(hasDoc, userData, email);
      let status = resolvedStatus(hasDoc, userData, email, role);

      return canReadManagedSurveyWithAccess(data, role, status);
    }

    function canEditManagedSurvey(data) {
      let email = userEmail();
      let hasDoc = isSignedIn() && hasUserDoc();
      let userData = hasDoc ? userDoc().data : {};
      let role = resolvedRole(hasDoc, userData, email);
      let status = resolvedStatus(hasDoc, userData, email, role);

      return canEditManagedSurveyWithAccess(data, role, status);
    }

    function canReadSurveyByIdWithAccess(surveyId, role, status) {
      let surveyPath = /databases/$(database)/documents/surveys/$(surveyId);
      let surveyExists = surveyId is string && exists(surveyPath);
      let surveyData = surveyExists ? get(surveyPath).data : {};

      return surveyExists && canReadManagedSurveyWithAccess(surveyData, role, status);
    }

    function canEditSurveyByIdWithAccess(surveyId, role, status) {
      let surveyPath = /databases/$(database)/documents/surveys/$(surveyId);
      let surveyExists = surveyId is string && exists(surveyPath);
      let surveyData = surveyExists ? get(surveyPath).data : {};

      return surveyExists && canEditManagedSurveyWithAccess(surveyData, role, status);
    }

    function canEditSurveyById(surveyId) {
      let email = userEmail();
      let hasDoc = isSignedIn() && hasUserDoc();
      let userData = hasDoc ? userDoc().data : {};
      let role = resolvedRole(hasDoc, userData, email);
      let status = resolvedStatus(hasDoc, userData, email, role);

      return canEditSurveyByIdWithAccess(surveyId, role, status);
    }

    function canReadSurveyTemplates() {
      let email = userEmail();
      let hasDoc = isSignedIn() && hasUserDoc();
      let userData = hasDoc ? userDoc().data : {};
      let role = resolvedRole(hasDoc, userData, email);
      let status = resolvedStatus(hasDoc, userData, email, role);

      return status == 'active' && role in ['super_admin', 'admin', 'creator'];
    }

    function canManageReportForSurvey(surveyId) {
      return canEditSurveyById(surveyId);
    }

    function canReadManagedReport(reportId, data) {
      let email = userEmail();
      let hasDoc = isSignedIn() && hasUserDoc();
      let userData = hasDoc ? userDoc().data : {};
      let role = resolvedRole(hasDoc, userData, email);
      let status = resolvedStatus(hasDoc, userData, email, role);
      let surveyId = data.keys().hasAny(["surveyId"]) && data.surveyId is string
        ? data.surveyId
        : reportId;

      return status == 'active' &&
        (
          role in ['super_admin', 'admin'] ||
          canReadSurveyByIdWithAccess(surveyId, role, status)
        );
    }

    function validReportCreate() {
      return canManageReportForSurvey(request.resource.data.surveyId) &&
        request.resource.data.keys().hasOnly([
          "surveyId",
          "title",
          "periodStart",
          "periodEnd",
          "period",
          "target",
          "department",
          "author",
          "reportDate",
          "sections",
          "status",
          "copiedFromReportId",
          "deleted",
          "deletedAt",
          "deletedBy",
          "createdBy",
          "updatedBy",
          "createdAt",
          "updatedAt"
        ]) &&
        request.resource.data.surveyId is string &&
        request.resource.data.title is string &&
        request.resource.data.periodStart is string &&
        request.resource.data.periodEnd is string &&
        request.resource.data.period is string &&
        request.resource.data.target is string &&
        request.resource.data.department is string &&
        request.resource.data.author is string &&
        request.resource.data.reportDate is string &&
        request.resource.data.sections is map &&
        request.resource.data.status in ["draft", "final"] &&
        request.resource.data.deleted is bool &&
        request.resource.data.updatedBy is map &&
        request.resource.data.updatedAt == request.time &&
        (
          !request.resource.data.keys().hasAny(["copiedFromReportId"]) ||
          request.resource.data.copiedFromReportId is string
        ) &&
        (
          !request.resource.data.keys().hasAny(["deletedAt"]) ||
          request.resource.data.deletedAt == null ||
          request.resource.data.deletedAt == request.time
        ) &&
        (
          !request.resource.data.keys().hasAny(["deletedBy"]) ||
          request.resource.data.deletedBy is map
        ) &&
        (
          !request.resource.data.keys().hasAny(["createdBy"]) ||
          request.resource.data.createdBy is map
        ) &&
        (
          !request.resource.data.keys().hasAny(["createdAt"]) ||
          request.resource.data.createdAt == request.time
        );
    }

    function validReportUpdate() {
      let changedKeys = request.resource.data.diff(resource.data).changedKeys();

      return resource.data.keys().hasAny(["surveyId"]) &&
        request.resource.data.surveyId == resource.data.surveyId &&
        canManageReportForSurvey(resource.data.surveyId) &&
        changedKeys.hasOnly([
          "title",
          "periodStart",
          "periodEnd",
          "period",
          "target",
          "department",
          "author",
          "reportDate",
          "sections",
          "status",
          "deleted",
          "deletedAt",
          "deletedBy",
          "updatedBy",
          "updatedAt"
        ]) &&
        request.resource.data.title is string &&
        request.resource.data.periodStart is string &&
        request.resource.data.periodEnd is string &&
        request.resource.data.period is string &&
        request.resource.data.target is string &&
        request.resource.data.department is string &&
        request.resource.data.author is string &&
        request.resource.data.reportDate is string &&
        request.resource.data.sections is map &&
        request.resource.data.status in ["draft", "final"] &&
        request.resource.data.deleted is bool &&
        request.resource.data.updatedBy is map &&
        request.resource.data.updatedAt == request.time &&
        (
          !changedKeys.hasAny(["deletedAt"]) ||
          request.resource.data.deletedAt == request.time
        ) &&
        (
          !changedKeys.hasAny(["deletedBy"]) ||
          request.resource.data.deletedBy is map
        );
    }

    function canReadManagedResponse(data) {
      let email = userEmail();
      let hasDoc = isSignedIn() && hasUserDoc();
      let userData = hasDoc ? userDoc().data : {};
      let role = resolvedRole(hasDoc, userData, email);
      let status = resolvedStatus(hasDoc, userData, email, role);

      return (
        status == 'active' &&
        role in ['super_admin', 'admin']
      ) || (
        data.surveyId is string &&
        (
          canReadSurveyByIdWithAccess(data.surveyId, role, status) ||
          (
            status == 'active' &&
            role == 'creator' &&
            isResponseOwner(data)
          )
        )
      );
    }

    function canEditManagedResponse(data) {
      let email = userEmail();
      let hasDoc = isSignedIn() && hasUserDoc();
      let userData = hasDoc ? userDoc().data : {};
      let role = resolvedRole(hasDoc, userData, email);
      let status = resolvedStatus(hasDoc, userData, email, role);

      return status == 'active' &&
        data.surveyId is string &&
        (
          role in ['super_admin', 'admin'] ||
          (
            role == 'creator' &&
            (
              isResponseOwner(data) ||
              canEditSurveyByIdWithAccess(data.surveyId, role, status)
            )
          )
        );
    }

    function canCreateAuditLog() {
      return request.resource.data.surveyId is string &&
        canEditSurveyById(request.resource.data.surveyId);
    }

    function validManagedSurveyCreate() {
      return isInternalUser() &&
        currentStatus() == 'active' &&
        currentRole() in ['super_admin', 'admin', 'creator'] &&
        request.resource.data.ownerUid == request.auth.uid &&
        request.resource.data.ownerEmail == userEmail();
    }

    function validPublicSurveyCounterUpdate() {
      let changedKeys = request.resource.data.diff(resource.data).changedKeys();

      return changedKeys.hasOnly(["optionQuotaCounts", "responseCount", "status", "updatedAt"]) &&
        surveyStatusForResponse(resource.data) &&
        request.resource.data.status in ["published", "closed"] &&
        (
          (!(resource.data.responseCount is int) && request.resource.data.responseCount == 1) ||
          (resource.data.responseCount is int &&
            request.resource.data.responseCount == resource.data.responseCount + 1)
        );
    }

    function canReadSurveySubdoc(surveyId) {
      let surveyPath = /databases/$(database)/documents/surveys/$(surveyId);
      let surveyExists = exists(surveyPath);
      let surveyData = surveyExists ? get(surveyPath).data : {};
      let email = userEmail();
      let hasDoc = isSignedIn() && hasUserDoc();
      let userData = hasDoc ? userDoc().data : {};
      let role = resolvedRole(hasDoc, userData, email);
      let status = resolvedStatus(hasDoc, userData, email, role);

      return surveyExists &&
        (
          surveyStatusForRead(surveyData) ||
          canReadManagedSurveyWithAccess(surveyData, role, status)
        );
    }

    function canEditSurveySubdoc(surveyId) {
      return exists(/databases/$(database)/documents/surveys/$(surveyId)) &&
        canEditManagedSurvey(get(/databases/$(database)/documents/surveys/$(surveyId)).data);
    }

    function validPublicQuotaCountsWrite(surveyId) {
      let surveyPath = /databases/$(database)/documents/surveys/$(surveyId);
      let surveyBefore = get(surveyPath).data;
      let surveyAfter = getAfter(surveyPath).data;

      return exists(surveyPath) &&
        surveyStatusForResponse(surveyBefore) &&
        request.resource.data.keys().hasOnly(["total", "cells", "updatedAt"]) &&
        request.resource.data.total is int &&
        request.resource.data.cells is map &&
        request.resource.data.updatedAt == request.time &&
        (
          (!(surveyBefore.responseCount is int) && surveyAfter.responseCount == 1) ||
          (surveyBefore.responseCount is int && surveyAfter.responseCount == surveyBefore.responseCount + 1)
        ) &&
        surveyAfter.status in ["published", "closed"];
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAtLeastAdmin());
      allow create: if isSignedIn() &&
        request.auth.uid == userId &&
        isInternalUser() &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.email == userEmail() &&
        (
          (isSuperAdminEmail() && request.resource.data.role == 'super_admin') ||
          (!isSuperAdminEmail() && (
            (
              request.resource.data.email is string &&
              hasMembership(request.resource.data.email) &&
              normalizedMembershipRole(request.resource.data.email) == request.resource.data.role &&
              request.resource.data.status == 'active'
            ) ||
            (
              request.resource.data.email is string &&
              request.resource.data.membershipId is string &&
              hasMembershipById(request.resource.data.membershipId) &&
              membershipEmailById(request.resource.data.membershipId) == request.resource.data.email &&
              normalizedMembershipRoleById(request.resource.data.membershipId) == request.resource.data.role &&
              request.resource.data.status == 'active'
            ) ||
            (
              request.resource.data.role == 'viewer' &&
              request.resource.data.status == 'pending' &&
              !hasMembership(request.resource.data.email)
            )
          ))
        );
      allow update: if isSignedIn() && (
        (isAtLeastAdmin() && (!protectedSuperAdminData(resource.data) || isSuperAdminEmail())) ||
        (
          request.auth.uid == userId &&
          resource.data.role == request.resource.data.role &&
          request.resource.data.email == resource.data.email
        )
      );
      allow delete: if isAtLeastAdmin() && (!protectedSuperAdminData(resource.data) || isSuperAdminEmail());
    }

    match /memberships/{membershipId} {
      allow read: if isAtLeastAdmin() || (
        isInternalUser() &&
        (
          membershipId == userEmail() ||
          resource.data.email == userEmail()
        )
      );
      allow create, update: if isAtLeastAdmin() &&
        (
          requestRole() != 'super_admin' ||
          isSuperAdminEmail()
        );
      allow delete: if isAtLeastAdmin();
    }

    match /surveys/{surveyId} {
      allow get: if surveyStatusForRead(resource.data) || canReadManagedSurvey(resource.data);
      allow list: if canListManagedSurveys(resource.data);
      allow create: if validManagedSurveyCreate();
      allow delete: if canEditManagedSurvey(resource.data);
      allow update: if canEditManagedSurvey(resource.data) || validPublicSurveyCounterUpdate();
    }

    match /surveys/{surveyId}/quotaConfig/{configId} {
      allow read: if canReadSurveySubdoc(surveyId);
      allow create, update, delete: if canEditSurveySubdoc(surveyId);
    }

    match /surveys/{surveyId}/quotaCounts/{countsId} {
      allow read: if canReadSurveySubdoc(surveyId);
      allow create, update: if canEditSurveySubdoc(surveyId) || validPublicQuotaCountsWrite(surveyId);
      allow delete: if canEditSurveySubdoc(surveyId);
    }

    match /surveys/{surveyId}/applicationApplicantLocks/{lockId} {
      allow read: if exists(/databases/$(database)/documents/surveys/$(surveyId)) &&
        surveyStatusForResponse(get(/databases/$(database)/documents/surveys/$(surveyId)).data);
      allow create: if
        request.resource.data.surveyId == surveyId &&
        request.resource.data.applicantHash is string &&
        request.resource.data.responseId is string &&
        request.resource.data.lockType in ['form_duplicate', 'one_slot_per_person'] &&
        exists(/databases/$(database)/documents/surveys/$(surveyId)) &&
        surveyStatusForResponse(get(/databases/$(database)/documents/surveys/$(surveyId)).data);
      allow update, delete: if false;
    }

    match /surveys/{surveyId}/applicationSlotLocks/{lockId} {
      allow read: if exists(/databases/$(database)/documents/surveys/$(surveyId)) &&
        surveyStatusForResponse(get(/databases/$(database)/documents/surveys/$(surveyId)).data);
      allow create: if
        request.resource.data.surveyId == surveyId &&
        request.resource.data.questionId is string &&
        request.resource.data.slotValue is string &&
        request.resource.data.applicantHash is string &&
        request.resource.data.responseId is string &&
        exists(/databases/$(database)/documents/surveys/$(surveyId)) &&
        surveyStatusForResponse(get(/databases/$(database)/documents/surveys/$(surveyId)).data);
      allow update, delete: if false;
    }

    match /surveys/{surveyId}/clientSubmitLocks/{lockId} {
      allow read: if exists(/databases/$(database)/documents/surveys/$(surveyId)) &&
        surveyStatusForRead(get(/databases/$(database)/documents/surveys/$(surveyId)).data);
      allow create: if
        request.resource.data.surveyId == surveyId &&
        request.resource.data.clientSubmitIdHash is string &&
        exists(/databases/$(database)/documents/surveys/$(surveyId)) &&
        surveyStatusForResponse(get(/databases/$(database)/documents/surveys/$(surveyId)).data);
      allow update, delete: if false;
    }

    // 공개 응답 제출(responses create)의 필드 화이트리스트.
    // submitSurveyResponse()(src/firebase/surveys.js)가 실제로 쓰는 top-level 필드와
    // 반드시 동기화 상태를 유지해야 한다 — 필드를 추가했는데 여기 반영하지 않으면
    // 정상 제출이 permission-denied로 막힌다(응답링크 미제출 원인이 될 수 있음).
    // 값이 항상 고정 상수인 필드(status/surveyDeleted 등)는 위조 방지를 위해
    // 값까지 강제한다. 소유자 스냅샷(surveyOwnerUid 등)은 legacy 설문의 소유자 필드가
    // 6종으로 혼재되어 있어(03_INFORMATION_ARCHITECTURE_REVIEW.md) 서버측 파생 없이
    // 안전하게 대조할 수 없으므로 이번 하드닝 범위에서는 타입 검증까지만 수행한다.
    function validPublicResponseCreate() {
      return request.resource.data.keys().hasOnly([
        "surveyId",
        "surveyTitle",
        "clientSubmitId",
        "surveyType",
        "surveyOwnerEmail",
        "surveyOwnerUid",
        "surveyCreatedByEmail",
        "surveyCreatedByUid",
        "surveyDeleted",
        "surveyPermanentlyDeleted",
        "hiddenFromDefaultList",
        "answers",
        "status",
        "responseMode",
        "visibleQuestionIds",
        "visibleSectionIds",
        "skippedQuestionIds",
        "quota",
        "respondent",
        "respondentName",
        "respondentPhone",
        "selectedSlotLabel",
        "adminNote",
        "submittedAt",
        "updatedAt"
      ]) &&
        request.resource.data.surveyId is string &&
        request.resource.data.surveyTitle is string &&
        request.resource.data.answers is list &&
        request.resource.data.respondent is map &&
        request.resource.data.status == "submitted" &&
        request.resource.data.surveyDeleted == false &&
        request.resource.data.surveyPermanentlyDeleted == false &&
        request.resource.data.hiddenFromDefaultList == false &&
        request.resource.data.adminNote == "" &&
        request.resource.data.submittedAt == request.time &&
        (
          !request.resource.data.keys().hasAny(["clientSubmitId"]) ||
          request.resource.data.clientSubmitId is string
        ) &&
        (
          !request.resource.data.keys().hasAny(["surveyType"]) ||
          request.resource.data.surveyType is string
        ) &&
        (
          !request.resource.data.keys().hasAny(["visibleQuestionIds"]) ||
          request.resource.data.visibleQuestionIds is list
        ) &&
        (
          !request.resource.data.keys().hasAny(["visibleSectionIds"]) ||
          request.resource.data.visibleSectionIds is list
        ) &&
        (
          !request.resource.data.keys().hasAny(["skippedQuestionIds"]) ||
          request.resource.data.skippedQuestionIds is list
        ) &&
        (
          !request.resource.data.keys().hasAny(["quota"]) ||
          request.resource.data.quota == null ||
          request.resource.data.quota is map
        );
    }

    match /responses/{responseId} {
      allow create: if
        validPublicResponseCreate() &&
        exists(/databases/$(database)/documents/surveys/$(request.resource.data.surveyId)) &&
        surveyStatusForResponse(
          get(/databases/$(database)/documents/surveys/$(request.resource.data.surveyId)).data
        ) &&
        (
          (
            !(get(/databases/$(database)/documents/surveys/$(request.resource.data.surveyId)).data.responseCount is int) &&
            getAfter(/databases/$(database)/documents/surveys/$(request.resource.data.surveyId)).data.responseCount == 1
          ) ||
          (
            get(/databases/$(database)/documents/surveys/$(request.resource.data.surveyId)).data.responseCount is int &&
            getAfter(/databases/$(database)/documents/surveys/$(request.resource.data.surveyId)).data.responseCount ==
              get(/databases/$(database)/documents/surveys/$(request.resource.data.surveyId)).data.responseCount + 1
          )
        ) &&
        getAfter(/databases/$(database)/documents/surveys/$(request.resource.data.surveyId)).data.status in ["published", "closed"];
      allow read: if canReadManagedResponse(resource.data);
      allow update: if canEditManagedResponse(resource.data);
      allow delete: if false;
    }

    match /survey_reports/{reportId} {
      allow get: if canReadManagedReport(reportId, resource.data);
      allow list: if canReadManagedReport(reportId, resource.data);
      allow create: if validReportCreate();
      allow update: if validReportUpdate();
      allow delete: if false;
    }

    match /survey_templates/{templateId} {
      allow get: if canReadSurveyTemplates();
      allow list: if canReadSurveyTemplates();
      allow create: if (isAtLeastAdmin() || isCreator()) &&
        request.resource.data.keys().hasOnly([
          "name",
          "description",
          "category",
          "surveyData",
          "sourceSurveyId",
          "copiedFromTemplateId",
          "usageCount",
          "active",
          "createdBy",
          "updatedBy",
          "createdAt",
          "updatedAt"
        ]) &&
        request.resource.data.name is string &&
        request.resource.data.description is string &&
        request.resource.data.category is string &&
        request.resource.data.surveyData is map &&
        request.resource.data.sourceSurveyId is string &&
        request.resource.data.usageCount == 0 &&
        request.resource.data.active == true &&
        request.resource.data.createdBy is map &&
        request.resource.data.createdBy.uid == request.auth.uid &&
        request.resource.data.updatedBy is map &&
        request.resource.data.updatedBy.uid == request.auth.uid &&
        request.resource.data.createdAt == request.time &&
        request.resource.data.updatedAt == request.time &&
        (
          !request.resource.data.keys().hasAny(["copiedFromTemplateId"]) ||
          request.resource.data.copiedFromTemplateId is string
        );
      allow update: if (
        isAtLeastAdmin() &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "name",
          "description",
          "category",
          "active",
          "updatedBy",
          "updatedAt"
        ]) &&
        request.resource.data.name is string &&
        request.resource.data.description is string &&
        request.resource.data.category is string &&
        request.resource.data.active is bool &&
        request.resource.data.updatedBy is map &&
        request.resource.data.updatedBy.uid == request.auth.uid &&
        request.resource.data.updatedAt == request.time
      ) || (
        (isAtLeastAdmin() || isCreator()) &&
        resource.data.active == true &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "usageCount"
        ]) &&
        request.resource.data.usageCount == resource.data.usageCount + 1
      );
      allow delete: if false;
    }

    match /audit_logs/{logId} {
      allow create: if canCreateAuditLog() &&
        request.resource.data.keys().hasOnly([
          "action",
          "surveyId",
          "responseId",
          "actor",
          "deletedBy",
          "deletedAt",
          "metadata",
          "createdAt"
        ]) &&
        request.resource.data.action is string &&
        request.resource.data.surveyId is string &&
        (
          request.resource.data.responseId == null ||
          request.resource.data.responseId is string
        ) &&
        request.resource.data.actor is map &&
        request.resource.data.actor.keys().hasOnly([
          "uid",
          "email",
          "displayName"
        ]) &&
        request.resource.data.actor.uid is string &&
        request.resource.data.actor.email is string &&
        request.resource.data.actor.displayName is string &&
        (
          !request.resource.data.keys().hasAny(["deletedBy"]) ||
          request.resource.data.deletedBy == null ||
          (
            request.resource.data.deletedBy is map &&
            request.resource.data.deletedBy.keys().hasOnly([
              "uid",
              "email",
              "displayName"
            ]) &&
            request.resource.data.deletedBy.uid is string &&
            request.resource.data.deletedBy.email is string &&
            request.resource.data.deletedBy.displayName is string
          )
        ) &&
        (
          !request.resource.data.keys().hasAny(["deletedAt"]) ||
          request.resource.data.deletedAt == null ||
          request.resource.data.deletedAt == request.time
        ) &&
        request.resource.data.metadata is map &&
        request.resource.data.createdAt == request.time;
      allow read: if isAtLeastAdmin();
      allow update, delete: if false;
    }

    match /draftResponses/{draftId} {
      allow read, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create, update: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }
  }
}
